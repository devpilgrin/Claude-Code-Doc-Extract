{
  "name": "@devpilgrin/claude-code-doc-extract",
  "version": "1.0.0",
  "description": "Claude Code plugin: auto-extract PDF, DOCX, XLSX to Markdown with embedded images. Zero native deps — pure JavaScript.",
  "main": "index.mjs",
  "type": "module",
  "bin": { "doc-extract": "cli.mjs" },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "pdf",
    "docx",
    "xlsx",
    "extract",
    "markdown",
    "document-parser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/devpilgrin/Claude-Code-Doc-Extract"
  },
  "claude": {
    "commands": [
      {
        "name": "extract-doc",
        "description": "Extract text and images from PDF/DOCX/XLSX into .temp/<filename>/ as markdown",
        "arguments": [
          { "name": "file", "description": "Path to the document file", "required": true }
        ]
      },
      {
        "name": "doc-extracted",
        "description": "Check if a document has been extracted. Without args — list all extracted documents.",
        "arguments": [
          { "name": "file", "description": "Path to original document (optional)", "required": false }
        ]
      }
    ],
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Read",
          "hooks": [
            {
              "type": "command",
              "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-read.mjs\""
            }
          ]
        }
      ]
    }
  },
  "dependencies": {
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.8.69",
    "xlsx": "^0.18.5"
  }
}
